PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX interop: <http://www.w3.org/ns/solid/interop#>
PREFIX acl: <http://www.w3.org/ns/auth/acl#>

<https://pod.demo.hackers4peace.net/acme/agentRegistry/alice/data-grant-projects-hr>
  a interop:DataGrant ;
    interop:dataOwner <https://pod.demo.hackers4peace.net/acme/profile/card#me> ;
    interop:grantee <https://pod.demo.hackers4peace.net/alice/profile/card#me> ;
    interop:grantedBy <https://dan.example/#id> ;
    interop:grantedWith <https://auth.acme.example/#agent> ;
    interop:grantedAt "2020-09-05T06:15:01Z"^^xsd:dateTime ;
    interop:registeredShapeTree <https://pod.demo.hackers4peace.net/shapetrees/trees/Project> ;
    interop:hasDataRegistration <https://pod.demo.hackers4peace.net/acme-hr/dataRegistry/projects/> ;
    interop:scopeOfGrant interop:AllFromRegistry ;
    interop:accessMode acl:Read, acl:Create, acl:Update, acl:Delete .

<https://pod.demo.hackers4peace.net/acme/agentRegistry/alice/data-grant-tasks-hr>
    interop:inheritsFromGrant <https://pod.demo.hackers4peace.net/acme/agentRegistry/alice/data-grant-projects-hr> .
